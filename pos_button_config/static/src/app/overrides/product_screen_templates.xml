<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_button_config.ActionpadWidget" t-inherit="point_of_sale.ActionpadWidget" t-inherit-mode="extension" owl="1">
        <xpath expr="//button[contains(@class, 'pay-order-button')]" position="attributes">
            <attribute name="t-att-disabled">!this.pos.config.wv_payment ? true : undefined</attribute>
        </xpath>
    </t>

    <t t-name="pos_button_config.ProductScreen" t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension" owl="1">
        <xpath expr="//button[contains(@class, 'pay-button')]" position="attributes">
            <attribute name="t-att-disabled">!this.pos.config.wv_payment ? true : undefined</attribute>
        </xpath>
    </t>
</templates>

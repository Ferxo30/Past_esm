<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Grupos -->
    <record id="group_pasteleria_admin" model="res.groups">
        <field name="name">Pastelería / Administrador</field>
        <field name="category_id" ref="base.module_category_inventory"/>
    </record>

    <record id="group_pasteleria_gerente" model="res.groups">
        <field name="name">Pastelería / Gerente</field>
        <field name="category_id" ref="base.module_category_inventory"/>
    </record>

    <record id="group_pasteleria_cajero" model="res.groups">
        <field name="name">Pastelería / Cajero</field>
        <field name="category_id" ref="base.module_category_inventory"/>
    </record>

    <!-- Cajero: solo ve sus propios desechos -->
    <record id="rule_desecho_cajero_own" model="ir.rule">
        <field name="name">Desechos: cajero solo propios</field>
        <field name="model_id" ref="model_pasteleria_desecho"/>
        <field name="domain_force">[('requested_by', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('pasteleria_desechos.group_pasteleria_cajero'))]"/>
    </record>

    <!-- Gerente: ve todos -->
    <record id="rule_desecho_gerente_all" model="ir.rule">
        <field name="name">Desechos: gerente ve todos</field>
        <field name="model_id" ref="model_pasteleria_desecho"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('pasteleria_desechos.group_pasteleria_gerente'))]"/>
    </record>

    <!-- Admin: ve todos -->
    <record id="rule_desecho_admin_all" model="ir.rule">
        <field name="name">Desechos: admin ve todos</field>
        <field name="model_id" ref="model_pasteleria_desecho"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('pasteleria_desechos.group_pasteleria_admin'))]"/>
    </record>
</odoo>
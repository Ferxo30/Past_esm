<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pasteleria_desecho_list" model="ir.ui.view">
        <field name="name">pasteleria.desecho.list</field>
        <field name="model">pasteleria.desecho</field>
        <field name="arch" type="xml">
            <list string="Desechos / Regalos" default_order="requested_date desc">
                <field name="name"/>
                <field name="operation_type"/>
                <field name="requested_date"/>
                <field name="warehouse_id"/>
                <field name="pos_config_id"/>
                <field name="requested_by"/>
                <field name="total_qty"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_pasteleria_desecho_form" model="ir.ui.view">
        <field name="name">pasteleria.desecho.form</field>
        <field name="model">pasteleria.desecho</field>
        <field name="arch" type="xml">
            <form string="Desecho / Regalo" create="1" edit="1">
                <header>
                    <button name="action_submit" type="object" string="Enviar" class="btn-primary"
                            invisible="state != 'draft'"
                            groups="pasteleria_desechos.group_pasteleria_cajero,pasteleria_desechos.group_pasteleria_gerente,pasteleria_desechos.group_pasteleria_admin"/>

                    <button name="action_confirm" type="object" string="Confirmar" class="btn-primary"
                            invisible="state != 'pending'"
                            groups="pasteleria_desechos.group_pasteleria_gerente,pasteleria_desechos.group_pasteleria_admin"/>

                    <button name="action_reject" type="object" string="Rechazar" class="btn-danger"
                            invisible="state != 'pending'"
                            groups="pasteleria_desechos.group_pasteleria_gerente,pasteleria_desechos.group_pasteleria_admin"/>

                    <button name="action_set_draft" type="object" string="Volver a Borrador"
                            invisible="state not in ('pending','rejected')"
                            groups="pasteleria_desechos.group_pasteleria_gerente,pasteleria_desechos.group_pasteleria_admin"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,confirmed,rejected"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <group>
                        <group>
                            <field name="operation_type" readonly="state != 'draft'"/>
                            <field name="warehouse_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="location_id" readonly="state != 'draft'"/>
                            <field name="pos_config_id" readonly="state != 'draft'"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="requested_by" readonly="1"/>
                            <field name="requested_date" readonly="1"/>
                            <field name="approved_by" readonly="1" invisible="state in ('draft','pending')"/>
                            <field name="approved_date" readonly="1" invisible="state in ('draft','pending')"/>
                            <field name="picking_id" readonly="1" invisible="state != 'confirmed'"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Detalle">
                            <field name="line_ids" readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="lot_id"/>
                                    <field name="product_uom_id"/>
                                    <field name="qty"/>
                                    <field name="reason"/>
                                </list>
                            </field>
                            <group>
                                <field name="total_qty" readonly="1"/>
                            </group>
                        </page>
                        <page string="Notas">
                            <field name="message_follower_ids" invisible="1"/>
                            <field name="message_ids" widget="mail_thread"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pasteleria_desechos" model="ir.actions.act_window">
        <field name="name">Desechos / Regalos</field>
        <field name="res_model">pasteleria.desecho</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_pasteleria_desechos_app" model="ir.actions.act_window">
        <field name="name">Desechos / Regalos</field>
        <field name="res_model">pasteleria.desecho</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea el primer registro de desecho o regalo.
            </p>
            <p>
                El inventario solo se mueve cuando un gerente confirma la solicitud.
            </p>
        </field>
    </record>
</odoo>
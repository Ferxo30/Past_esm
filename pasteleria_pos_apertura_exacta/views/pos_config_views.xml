<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_config_form_apertura_exacta" model="ir.ui.view">
        <field name="name">pos.config.form.apertura.exacta</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet" position="inside">
                <group string="Apertura exacta de caja">
                    <group>
                        <field name="x_cash_opening_exact_enabled"/>
                        <field name="x_cash_opening_expected_amount"
                               readonly="not x_cash_opening_exact_enabled"/>
                    </group>
                    <div class="text-muted">
                        Cuando esta opción está activa, el monto contado al abrir caja debe coincidir exactamente con el monto esperado configurado.
                        Este módulo no reemplaza la sesión nativa del POS; solo agrega la validación.
                    </div>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
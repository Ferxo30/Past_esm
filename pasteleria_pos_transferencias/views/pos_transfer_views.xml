<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pasteleria_pos_transfer_tree" model="ir.ui.view">
        <field name="name">pasteleria.pos.transfer.tree</field>
        <field name="model">pasteleria.pos.transfer</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="origin_pos_id"/>
                <field name="destination_pos_id"/>
                <field name="state"/>
                <field name="user_id"/>
                <field name="picking_id"/>
            </list>
        </field>
    </record>

    <record id="view_pasteleria_pos_transfer_form" model="ir.ui.view">
        <field name="name">pasteleria.pos.transfer.form</field>
        <field name="model">pasteleria.pos.transfer</field>
        <field name="arch" type="xml">
            <form string="Transferencia POS">
                <header>
                    <button name="action_confirm"
                            type="object"
                            string="Confirmar"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel"
                            type="object"
                            string="Cancelar"
                            invisible="state == 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="date"/>
                            <field name="user_id" readonly="1"/>
                            <field name="origin_pos_id"/>
                            <field name="destination_pos_id" domain="[('id', 'in', allowed_destination_pos_ids)]"/>
                        </group>
                        <group>
                            <field name="picking_type_id" readonly="1" force_save="1"/>
                            <field name="source_location_id" readonly="1" force_save="1"/>
                            <field name="destination_location_id" readonly="1" force_save="1"/>
                            <field name="picking_id" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Productos / Lotes">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="lot_id"/>
                                    <field name="lot_expiration_date" readonly="1"/>
                                    <field name="lot_expiry_state" readonly="1"/>
                                    <field name="available_qty" readonly="1"/>
                                    <field name="qty"/>
                                    <field name="uom_id" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notas">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pasteleria_pos_transfer_line_tree" model="ir.ui.view">
        <field name="name">pasteleria.pos.transfer.line.tree</field>
        <field name="model">pasteleria.pos.transfer.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="transfer_id"/>
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="lot_expiration_date"/>
                <field name="lot_expiry_state"/>
                <field name="available_qty"/>
                <field name="qty"/>
                <field name="uom_id"/>
            </list>
        </field>
    </record>

    <record id="action_pasteleria_pos_transfer" model="ir.actions.act_window">
        <field name="name">Transferencias POS</field>
        <field name="res_model">pasteleria.pos.transfer</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pasteleria_cake_fraction_reason_tree" model="ir.ui.view">
        <field name="name">pasteleria.cake.fraction.reason.tree</field>
        <field name="model">pasteleria.cake.fraction.reason</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_pasteleria_cake_fraction_reason_form" model="ir.ui.view">
        <field name="name">pasteleria.cake.fraction.reason.form</field>
        <field name="model">pasteleria.cake.fraction.reason</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pasteleria_cake_fraction_reason" model="ir.actions.act_window">
        <field name="name">Motivos de fraccionamiento</field>
        <field name="res_model">pasteleria.cake.fraction.reason</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pasteleria_report_template_line_list" model="ir.ui.view">
        <field name="name">pasteleria.pos.report.template.line.list</field>
        <field name="model">pasteleria.pos.report.template.line</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="active"/>
                <field name="name"/>
                <field name="product_pq_id"/>
                <field name="product_gr_id"/>
                <field name="product_p_id"/>
            </list>
        </field>
    </record>

    <record id="view_pasteleria_report_template_line_form" model="ir.ui.view">
        <field name="name">pasteleria.pos.report.template.line.form</field>
        <field name="model">pasteleria.pos.report.template.line</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="active"/>
                            <field name="sequence"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="product_pq_id"/>
                            <field name="product_gr_id"/>
                            <field name="product_p_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pasteleria_report_template_line" model="ir.actions.act_window">
        <field name="name">Plantilla Reporte Final Día</field>
        <field name="res_model">pasteleria.pos.report.template.line</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_daily_report_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 style="margin-bottom: 12px;">Reporte Final del Día</h2>

                        <table style="width: 100%; margin-bottom: 18px; border-collapse: collapse;">
                            <tr>
                                <td style="padding: 4px;"><strong>Reporte:</strong> <span t-field="o.name"/></td>
                                <td style="padding: 4px;"><strong>Fecha:</strong> <span t-field="o.report_date"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 4px;"><strong>Sesión POS:</strong> <span t-field="o.session_id"/></td>
                                <td style="padding: 4px;"><strong>Punto de Venta:</strong> <span t-field="o.config_id"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 4px;"><strong>Apertura:</strong> <span t-field="o.date_open"/></td>
                                <td style="padding: 4px;"><strong>Cierre:</strong> <span t-field="o.date_close"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 4px;"><strong>Usuario cierre:</strong> <span t-field="o.user_id"/></td>
                                <td style="padding: 4px;"><strong>Total Q:</strong> <span t-field="o.total_amount_q"/></td>
                            </tr>
                        </table>

                        <table class="table table-sm table-bordered" style="width:100%; border-collapse: collapse; font-size: 11px;">
                            <thead>
                                <tr>
                                    <th style="padding: 4px;">Tipo</th>
                                    <th style="padding: 4px;">Categoría</th>
                                    <th style="padding: 4px;">Descripción</th>
                                    <th style="padding: 4px;">Exist. E</th>
                                    <th style="padding: 4px;">Exist. Pq</th>
                                    <th style="padding: 4px;">Exist. Gr</th>
                                    <th style="padding: 4px;">Exist. Otras</th>
                                    <th style="padding: 4px;">Ing. E</th>
                                    <th style="padding: 4px;">Ing. Pq</th>
                                    <th style="padding: 4px;">Ing. Gr</th>
                                    <th style="padding: 4px;">Ing. Otras</th>
                                    <th style="padding: 4px;">Venta E</th>
                                    <th style="padding: 4px;">Venta Pq</th>
                                    <th style="padding: 4px;">Venta Gr</th>
                                    <th style="padding: 4px;">Venta Otras</th>
                                    <th style="padding: 4px;">VTA-Q</th>
                                    <th style="padding: 4px;">Saldo E</th>
                                    <th style="padding: 4px;">Saldo Pq</th>
                                    <th style="padding: 4px;">Saldo Gr</th>
                                    <th style="padding: 4px;">Saldo Otras</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.line_ids" t-as="line">
                                    <tr t-att-style="
                                        'background-color:#f4cccc;font-weight:bold;' if line.line_type == 'category'
                                        else 'background-color:#fff2cc;font-weight:bold;' if line.line_type == 'subtotal'
                                        else ''
                                    ">
                                        <td style="padding: 4px;"><span t-field="line.line_type"/></td>
                                        <td style="padding: 4px;"><span t-field="line.category_name"/></td>
                                        <td style="padding: 4px;"><span t-field="line.display_name"/></td>
                                        <td style="padding: 4px; text-align:center;"><span t-field="line.exist_e"/></td>
                                        <td style="padding: 4px; text-align:center;"><span t-field="line.exist_pq"/></td>
                                        <td style="padding: 4px; text-align:center;"><span t-field="line.exist_gr"/></td>
                                        <td style="padding: 4px; text-align:center;"><span t-field="line.exist_p"/></td>
                                        <td style="padding: 4px; text-align:center;"><span t-field="line.income_e"/></td>
                                        <td style="padding: 4px; text-align:center;"><span t-field="line.income_pq"/></td>
                                        <td style="padding: 4px; text-align:center;"><span t-field="line.income_gr"/></td>
                                        <td style="padding: 4px; text-align:center;"><span t-field="line.income_p"/></td>
                                        <td style="padding: 4px; text-align:center;"><span t-field="line.sales_e"/></td>
                                        <td style="padding: 4px; text-align:center;"><span t-field="line.sales_pq"/></td>
                                        <td style="padding: 4px; text-align:center;"><span t-field="line.sales_gr"/></td>
                                        <td style="padding: 4px; text-align:center;"><span t-field="line.sales_p"/></td>
                                        <td style="padding: 4px; text-align:center;"><span t-field="line.sales_amount_q"/></td>
                                        <td style="padding: 4px; text-align:center;"><span t-field="line.final_e"/></td>
                                        <td style="padding: 4px; text-align:center;"><span t-field="line.final_pq"/></td>
                                        <td style="padding: 4px; text-align:center;"><span t-field="line.final_gr"/></td>
                                        <td style="padding: 4px; text-align:center;"><span t-field="line.final_p"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <div style="margin-top: 18px;">
                            <strong>Resumen</strong>
                            <div style="white-space: pre-wrap; margin-top: 6px;">
                                <span t-field="o.summary_text"/>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
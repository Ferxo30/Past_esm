<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_daily_report_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-size: 9px;">

                        <h3 style="text-align:center; margin:0 0 6px 0;">PASTELERÍA ESMERALDA</h3>

                        <table style="width:100%; border-collapse:collapse; margin-bottom:6px;">
                            <tr>
                                <td style="padding:2px;"><strong>Reporte:</strong> <span t-field="o.name"/></td>
                                <td style="padding:2px;"><strong>Sesión:</strong> <span t-field="o.session_id"/></td>
                                <td style="padding:2px;"><strong>POS:</strong> <span t-field="o.config_id"/></td>
                                <td style="padding:2px;"><strong>Fecha:</strong> <span t-field="o.report_date"/></td>
                            </tr>
                            <tr>
                                <td style="padding:2px;"><strong>Apertura:</strong> <span t-field="o.date_open"/></td>
                                <td style="padding:2px;"><strong>Cierre:</strong> <span t-field="o.date_close"/></td>
                                <td style="padding:2px;"><strong>Usuario:</strong> <span t-field="o.user_id"/></td>
                                <td style="padding:2px;"><strong>Total Q:</strong> <span t-field="o.total_amount_q"/></td>
                            </tr>
                        </table>

                        <table style="width:100%; border-collapse:collapse;" border="1">
                            <thead>
                                <tr style="background:#eeeeee;">
                                    <th rowspan="2" style="padding:2px;">Descripción</th>

                                    <th colspan="4" style="padding:2px;">Existencia</th>
                                    <th colspan="4" style="padding:2px;">Ingresos</th>
                                    <th colspan="4" style="padding:2px;">Egresos</th>
                                    <th colspan="4" style="padding:2px;">Desechos</th>
                                    <th colspan="4" style="padding:2px;">Ventas del día</th>

                                    <th rowspan="2" style="padding:2px;">VTA-Q</th>

                                    <th colspan="4" style="padding:2px;">Saldo final</th>
                                </tr>
                                <tr style="background:#eeeeee;">
                                    <th style="padding:2px;">E</th>
                                    <th style="padding:2px;">Pq</th>
                                    <th style="padding:2px;">Gr</th>
                                    <th style="padding:2px;">P</th>

                                    <th style="padding:2px;">E</th>
                                    <th style="padding:2px;">Pq</th>
                                    <th style="padding:2px;">Gr</th>
                                    <th style="padding:2px;">P</th>

                                    <th style="padding:2px;">E</th>
                                    <th style="padding:2px;">Pq</th>
                                    <th style="padding:2px;">Gr</th>
                                    <th style="padding:2px;">P</th>

                                    <th style="padding:2px;">E</th>
                                    <th style="padding:2px;">Pq</th>
                                    <th style="padding:2px;">Gr</th>
                                    <th style="padding:2px;">P</th>

                                    <th style="padding:2px;">E</th>
                                    <th style="padding:2px;">Pq</th>
                                    <th style="padding:2px;">Gr</th>
                                    <th style="padding:2px;">P</th>

                                    <th style="padding:2px;">E</th>
                                    <th style="padding:2px;">Pq</th>
                                    <th style="padding:2px;">Gr</th>
                                    <th style="padding:2px;">P</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.line_ids" t-as="line">
                                    <tr t-att-style="
                                        'background-color:#f4cccc;font-weight:bold;' if line.line_type == 'category'
                                        else 'background-color:#fff2cc;font-weight:bold;' if line.line_type == 'subtotal'
                                        else ''
                                    ">
                                        <td style="padding:2px;"><span t-field="line.display_name"/></td>

                                        <td style="padding:2px; text-align:center;"><span t-field="line.exist_e"/></td>
                                        <td style="padding:2px; text-align:center;"><span t-field="line.exist_pq"/></td>
                                        <td style="padding:2px; text-align:center;"><span t-field="line.exist_gr"/></td>
                                        <td style="padding:2px; text-align:center;"><span t-field="line.exist_p"/></td>

                                        <td style="padding:2px; text-align:center;"><span t-field="line.income_e"/></td>
                                        <td style="padding:2px; text-align:center;"><span t-field="line.income_pq"/></td>
                                        <td style="padding:2px; text-align:center;"><span t-field="line.income_gr"/></td>
                                        <td style="padding:2px; text-align:center;"><span t-field="line.income_p"/></td>

                                        <td style="padding:2px; text-align:center;"><span t-field="line.expense_e"/></td>
                                        <td style="padding:2px; text-align:center;"><span t-field="line.expense_pq"/></td>
                                        <td style="padding:2px; text-align:center;"><span t-field="line.expense_gr"/></td>
                                        <td style="padding:2px; text-align:center;"><span t-field="line.expense_p"/></td>

                                        <td style="padding:2px; text-align:center;"><span t-field="line.waste_e"/></td>
                                        <td style="padding:2px; text-align:center;"><span t-field="line.waste_pq"/></td>
                                        <td style="padding:2px; text-align:center;"><span t-field="line.waste_gr"/></td>
                                        <td style="padding:2px; text-align:center;"><span t-field="line.waste_p"/></td>

                                        <td style="padding:2px; text-align:center;"><span t-field="line.sales_e"/></td>
                                        <td style="padding:2px; text-align:center;"><span t-field="line.sales_pq"/></td>
                                        <td style="padding:2px; text-align:center;"><span t-field="line.sales_gr"/></td>
                                        <td style="padding:2px; text-align:center;"><span t-field="line.sales_p"/></td>

                                        <td style="padding:2px; text-align:center;"><span t-field="line.sales_amount_q"/></td>

                                        <td style="padding:2px; text-align:center;"><span t-field="line.final_e"/></td>
                                        <td style="padding:2px; text-align:center;"><span t-field="line.final_pq"/></td>
                                        <td style="padding:2px; text-align:center;"><span t-field="line.final_gr"/></td>
                                        <td style="padding:2px; text-align:center;"><span t-field="line.final_p"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <div style="margin-top:8px;">
                            <strong>Resumen:</strong>
                            <div style="white-space: pre-wrap;">
                                <span t-field="o.summary_text"/>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
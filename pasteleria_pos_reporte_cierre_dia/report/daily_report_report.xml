<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_pasteleria_daily_report" model="report.paperformat">
        <field name="name">Pastelería Reporte Final Día</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">3</field>
        <field name="margin_bottom">3</field>
        <field name="margin_left">3</field>
        <field name="margin_right">3</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">1</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_daily_report_pdf" model="ir.actions.report">
        <field name="name">Reporte Final del Día</field>
        <field name="model">pasteleria.pos.daily.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pasteleria_pos_reporte_cierre_dia.report_daily_report_pdf</field>
        <field name="report_file">pasteleria_pos_reporte_cierre_dia.report_daily_report_pdf</field>
        <field name="print_report_name">'Reporte Final del Día - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_pasteleria_pos_daily_report"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_pasteleria_daily_report"/>
    </record>
</odoo>